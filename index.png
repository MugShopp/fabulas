<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Fábulas Café</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(to bottom right, #fdf6ec, #f1e4d0);
      overflow: hidden;
      font-family: Arial, sans-serif;
      height: 100vh;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      color: #4b2e2e;
      padding: 20px;
    }

    .mensagem {
      font-size: 28px;
      text-align: center;
      animation: fadeInUp 2s ease-out;
      white-space: pre-line;
      z-index: 2;
      margin-bottom: 30px;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .icon-link {
      display: flex;
      align-items: center;
      gap: 15px;
      background: rgba(255, 255, 255, 0.9);
      border-radius: 12px;
      padding: 15px 20px;
      margin: 10px 0;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      text-decoration: none;
      color: #4b2e2e;
      font-size: 1.1em;
      transition: background 0.3s ease;
      width: 100%;
      max-width: 400px;
    }

    .icon-link:hover {
      background: #fff2e0;
    }

    .icon-link img {
      width: 32px;
      height: 32px;
    }

    .logo-final {
      margin-top: 40px;
      opacity: 0.8;
      z-index: 2;
    }

    .logo-final img {
      width: 100px;
    }

    .floating {
      position: fixed;
      width: 100%;
      height: 100%;
      pointer-events: none;
      overflow: hidden;
      z-index: 1;
    }

    .cup {
      position: absolute;
      width: 40px;
      height: 40px;
      background-image: url('Xica.png');
      background-size: cover;
      animation: floatUp 12s linear infinite;
      opacity: 0.12;
    }

    @keyframes floatUp {
      0% {
        transform: translateY(100vh) scale(0.8);
        opacity: 0;
      }
      30% {
        opacity: 0.6;
      }
      100% {
        transform: translateY(-10vh) scale(1.2);
        opacity: 0;
      }
    }
  </style>
</head>
<body>

  <div class="mensagem">Bem-vindo ao Fábulas Café ☕\nEscolha abaixo uma opção:</div>

  <a class="icon-link" href="https://wa.me/message/XJOCYNPNDO4DD1" target="_blank">
    <img src="whats.png" alt="WhatsApp"/>
    Anote nosso número na sua agenda
  </a>

  <a class="icon-link" href="https://g.page/r/CS9Wjb4xq5aJEBE/review" target="_blank">
    <img src="google.png" alt="Google Avaliações"/>
    Avalie-nos no Google
  </a>

  <a class="icon-link" href="https://www.instagram.com/mug.shopp?igsh=NHMxZ3pvZXVudGdq" target="_blank">
    <img src="insta.png" alt="Instagram"/>
    Siga-nos no Instagram
  </a>

  <div class="icon-link" style="cursor: default;">
    <img src="wifi.png" alt="Wi-Fi"/>
    Conecte-se à nossa rede Wi-Fi:<br/>
    <strong>fábulas café</strong><br/>
    Senha: <strong>Cafe2025</strong>
  </div>

  <div class="logo-final">
    <img src="Fabu.png" alt="Logo Fábulas Café" />
  </div>

  <div class="floating" id="floating"></div>

  <script>
    function createCup() {
      const cup = document.createElement('div');
      cup.classList.add('cup');
      cup.style.left = Math.random() * 100 + 'vw';
      cup.style.animationDuration = 8 + Math.random() * 4 + 's';
      document.getElementById('floating').appendChild(cup);
      setTimeout(() => cup.remove(), 12000);
    }
    setInterval(createCup, 300);
  </script>

</body>
</html>
